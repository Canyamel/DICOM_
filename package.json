{
  "name": "medml-front",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "lib/*",
    "domains/*"
  ],
  "scripts": {
    "dev:cytology": "turbo dev --filter=cytology-app",
    "build:cytology": "turbo build --filter=cytology-app",
    "dev:ultrasound": "turbo run dev --filter=ultrasound-app",
    "build:ultrasound": "turbo run build --filter=ultrasound-app",
    "dev:ct": "turbo dev --filter=ct-app",
    "build:ct": "turbo build --filter=ct-app",
    "dev:mri": "turbo dev --filter=mri-app",
    "build:mri": "turbo build --filter=mri-app",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check:boundaries": "node tools/scripts/check-boundaries.mjs",
    "workspaces:list": "node tools/scripts/list-workspaces.mjs"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@ant-design/nextjs-registry": "^1.0.1",
    "@reduxjs/toolkit": "^2.0.0",
    "antd": "^5.12.0",
    "form-data": "^4.0.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-redux": "^9.0.0"
  },
  "overrides": {
    "@cornerstonejs/core": "4.15.31",
    "@cornerstonejs/dicom-image-loader": "4.15.31",
    "@cornerstonejs/tools": "4.15.31",
    "@cornerstonejs/polymorphic-segmentation": "4.15.31"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.1.0",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.0.0",
    "sass": "^1.83.0",
    "turbo": "^1.13.4",
    "typescript-eslint": "^8.53.0"
  }
}
